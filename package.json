{
  "name": "desafio-dev",
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "shared",
      "ui"
    ],
    "catalog": {
      "zod": "^4.1.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "clean": "rm -rf node_modules && rm -rf api/node_modules && rm -rf ui/node_modules && rm -rf apps/*/dist && rm -rf shared/node_modules",
    "dev:web": "turbo -F @desafio-dev/ui dev",
    "dev:server": "turbo -F @desafio-dev/api dev",
    "db:push": "turbo -F @desafio-dev/api db:push",
    "db:studio": "turbo -F @desafio-dev/api db:studio",
    "db:generate": "turbo -F @desafio-dev/api db:generate",
    "db:migrate": "turbo -F @desafio-dev/api db:migrate",
    "db:local": "turbo -F @desafio-dev/api db:local"
  },
  "dependencies": {
    "@desafio-dev/shared": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.5"
}
